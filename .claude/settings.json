{
  "enabledPlugins": {
    "ralph-skills@ralph-marketplace": true,
    "ralph-wiggum@claude-code-plugins": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool-lint.sh",
            "timeout": 60,
            "statusMessage": "Running ESLint validation..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool-typecheck.sh",
            "timeout": 60,
            "statusMessage": "Running TypeScript type check..."
          }
        ]
      }
    ]
  }
}
