{
  "name": "@echoe/server",
  "version": "0.9.0",
  "private": true,
  "license": "BSL-1.1",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec node --loader ts-node/esm ./src/index.ts",
    "dev:old": "NODE_ENV=development tsx watch src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "start:env": "./docker/dev-start.sh",
    "test": "NODE_ENV=test jest",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix --fix-type problem",
    "migrate": "node --loader ts-node/esm ./src/db/migrate.ts",
    "migrate:generate": "drizzle-kit generate",
    "migrate:studio": "drizzle-kit studio",
    "migrate:data": "tsx src/scripts/migrate-lancedb-to-mysql.ts",
    "verify:indexes": "tsx src/scripts/verify-indexes.ts",
    "validate:data": "tsx scripts/validate-data-integrity.ts"
  },
  "type": "module",
  "dependencies": {
